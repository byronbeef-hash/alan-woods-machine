# Woods System — Environment Variables
# Copy this to .env and fill in your values

# Mode: "demo" for paper trading, "live" for real money
WOODS_MODE=demo

# The Odds API (required for live odds)
# Get a free key at https://the-odds-api.com
ODDS_API_KEY=YOUR_API_KEY_HERE

# Supabase (persistent cloud storage)
# Get these from your Supabase project: Settings > API
SUPABASE_URL=
SUPABASE_KEY=

# Schedule (24h format, ET timezone)
WOODS_SCAN_TIME=17:00
WOODS_RESULTS_TIME=23:30

# Telegram notifications (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email notifications (optional)
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# Betfair API (only needed for live mode)
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
